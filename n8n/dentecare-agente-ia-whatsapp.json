      "id": "dc000001-0000-0000-0000-000000000005",
      "name": "Buscar Historico",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [-40, 0]
    },
    {
      "parameters": {
        "jsCode": "var allItems = $input.all();\nvar raw = allItems[0].json;\nvar mensagens = Array.isArray(raw) ? raw : allItems.map(function(i) { return i.json; });\n\nvar filtrar = $('Filtrar e Extrair Mensagem').all()[0].json;\nvar nome = filtrar.nomeContato || 'Cliente';\nvar msgAtual = filtrar.mensagem || '';\n\nvar historico = mensagens.slice(0, -1);\n\nvar prompt = '';\n\nif (historico.length > 0) {\n  var linhas = '';\n  for (var i = 0; i < historico.length; i++) {\n    var role = historico[i].direction === 'inbound' ? nome : 'Clara';\n    linhas += role + ': ' + historico[i].content + '\\n';\n  }\n  prompt += '[HISTORICO DA CONVERSA - voce JA se apresentou, NAO se reapresente]\\n' + linhas + '[FIM DO HISTORICO]\\n\\n';\n  prompt += 'Nova mensagem de ' + nome + ': ' + msgAtual;\n} else {\n  prompt += '[PRIMEIRA MENSAGEM - apresente-se brevemente como Clara da DenteCare e pergunte como pode ajudar]\\n';\n  prompt += nome + ': ' + msgAtual;\n}\n\nreturn [{ json: { prompt: prompt, primeiraMsg: historico.length === 0, historicoLength: historico.length, totalMsgs: mensagens.length } }];\n"
      },
