      "parameters": {
        "jsCode": "const body       = $input.first().json.body;\nconst event      = body?.event;\nconst key        = body?.data?.key ?? {};\nconst fromMe     = key.fromMe;\nconst remoteJid  = key.remoteJid ?? '';\nconst msgData    = body?.data?.message ?? {};\nconst text       = msgData.conversation ?? msgData.extendedTextMessage?.text ?? null;\n\nif (fromMe === true || event !== 'messages.upsert' || remoteJid.includes('@g.us') || !text) {\n  return [];\n}\n\nconst telefone = remoteJid\n  .replace('@s.whatsapp.net', '')\n  .replace('@g.us', '')\n  .replace('@lid', '');\n\nreturn [{\n  json: {\n    remoteJid,\n    telefone,\n    mensagem:    text,\n    nomeContato: body?.data?.pushName ?? 'Cliente',\n    sessionId:   remoteJid,\n    instancia:   body?.instance ?? ''\n  }\n}];\n"
      },
